# Langfuse Cleaner — 环境变量配置

# 登录密码（明文）
LOGIN_PASSWORD=admin123

# JWT 签名密钥（至少 32 字节随机字符串）
JWT_SECRET=dev-secret-change-me-to-a-long-random-string

# Langfuse 连接信息
LANGFUSE_HOST=https://langfuse.cloudwise.com

# Langfuse 数据库容器名（用于 docker exec 获取项目列表）
POSTGRES_CONTAINER=langfuse-postgres-1

# MinIO / S3 对象存储配置（可选，不配则跳过文件清理）
# MINIO_ENDPOINT=http://116.204.118.233:9090
# MINIO_ACCESS_KEY=minio
# MINIO_SECRET_KEY=miniosecret
# MINIO_BUCKET=langfuse
# MINIO_EVENTS_PREFIX=events
# MINIO_SECURE=false
